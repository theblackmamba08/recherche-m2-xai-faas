#!/usr/bin/env bash
#SBATCH --job-name=h1-baseline
#SBATCH --output=hpc/logs/%x-%j.out
#SBATCH --error=hpc/logs/%x-%j.err
#SBATCH --time=04:00:00
#SBATCH --gres=gpu:1
#SBATCH --cpus-per-task=4
#SBATCH --mem=16G

# Exemple — à adapter au cluster cible (modules, partition, account…)

set -euo pipefail

module purge
# module load python/3.10 cuda/12.1   # exemple, à ajuster

cd "$SLURM_SUBMIT_DIR/code"

source .venv/bin/activate
python -m src.experiments.run_h1 --config experiments/configs/h1-baseline.yaml
